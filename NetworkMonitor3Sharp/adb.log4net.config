<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  
  <configSections>
    <section name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler, log4net"/>
  </configSections>

  <log4net>
    <root>
      <level value="INFO"/>
      <appender-ref ref="LogFile"/>
    </root>
	  
	<appender name="LogFile" type="log4net.Appender.RollingFileAppender">
		<file value="${USERPROFILE}\Documents\log\MonitorNetwork.log"/>
    <!--file value="D:\log\MonitorNetwork.log"/-->
		<appendToFile value="true"/>
		<rollingStyle value="Size"/>
		<maxSizeRollBackups value="50"/>
		<maximumFileSize value="10MB"/>
		<staticLogFileName value="true"/>
		<CountDirection value="1"/>
		<layout type="log4net.Layout.PatternLayout">
			<conversionPattern value="%date{yyyy.MM.dd HH:mm:ss.fff}%property{tab}%-5level%property{tab}%message%newline" />
		</layout>
	</appender>
	  
    <!--
    <logger name="NetworkMonitor.SharpTraps" additivity="false">
      <level value="DEBUG"/>
      <appender-ref ref="LogFile"/>
    </logger>

    <logger name="NetworkMonitor.GUI" additivity="false">
      <level value="INFO"/>
      <appender-ref ref="LogFile"/>
    </logger>
    
    <logger name="NetworkMonitor.wincc" additivity="false">
      <level value="INFO"/>
      <appender-ref ref="LogFile"/>
    </logger>

    <logger name="NetworkMonitor.ICMP" additivity="false">
      <level value="INFO"/>
      <appender-ref ref="LogFile"/>
    </logger>
    
    <logger name="NetworkMonitor.snmpLib" additivity="false">
      <level value="INFO"/>
      <appender-ref ref="LogFile"/>
    </logger>
-->

  </log4net>
  
</configuration>
