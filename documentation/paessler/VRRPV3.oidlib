      <entry>
        <name>
          VRRPV3-MIB|vrrpv3operations: #[1.3.6.1.2.1.2.2.1.2]|vrrpv3operations status: #[1.3.6.1.2.1.207.1.1.1.1.1] #[1.3.6.1.2.1.207.1.1.1.1.2]
        </name>
