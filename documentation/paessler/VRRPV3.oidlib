          VRRPV3-MIB|vrrpv3operations: #[1.3.6.1.2.1.2.2.1.2]|vrrpv3operations master ip addr: #[1.3.6.1.2.1.207.1.1.1.1.1] #[1.3.6.1.2.1.207.1.1.1.1.2]
